# rebalancing-client environment variables
#
# These override stored config in ~/.rebalancing-client/config.json.
# Useful for CI/CD, scripts, and agent integrations (e.g. Týr).
#
# Copy to .env and fill in your values. Never commit .env.

# API base URL — defaults to https://app.rebalancing.accordant.eu
# REBALANCING_API_URL=https://app.rebalancing.accordant.eu

# Bearer token — obtain via `rebalancing auth login`, or set directly for
# non-interactive use (e.g. CI, Týr agent).
# REBALANCING_API_TOKEN=
